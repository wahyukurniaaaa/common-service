# ============================================
# SQL Server Target Configuration
# ============================================
MSSQL_HOST=127.0.0.1
MSSQL_PORT=1433
MSSQL_DB=smartoffice
MSSQL_USER=sa
MSSQL_PASSWORD=your_mssql_password
MSSQL_PID=Express
ACCEPT_EULA=Y

# ============================================
# SQL Server Source (for direct pull on first run)
# ============================================
MSSQL_SOURCE_HOST=host.docker.internal
MSSQL_SOURCE_PORT=1433
MSSQL_SOURCE_DB=smartoffice_source_db
MSSQL_SOURCE_USER=sa
MSSQL_SOURCE_PASS=your_mssql_source_password

# ============================================
# PostgreSQL Target Configuration
# ============================================
PG_HOST=127.0.0.1
PG_PORT=5435
PG_DB=phiro_multi_dev
PG_USER=postgres
PG_PASSWORD=your_pg_password

# ============================================
# PostgreSQL Source (for direct pull on first run)
# ============================================
PG_SOURCE_HOST=host.docker.internal
PG_SOURCE_PORT=55321
PG_SOURCE_DB=phiro_multi_dev
PG_SOURCE_USER=your_pg_source_username
PG_SOURCE_PASS=your_pg_source_password
